# Copy this file to .env.local and fill in the key(s) you need.
# Only ANTHROPIC_API_KEY (or GEMINI_API_KEY) is required to run; everything else
# is optional and unlocks an extra lead source. Missing keys → that source/AI
# simply falls back to simulated data; nothing crashes.

# ── AI providers (need at least one) ────────────────────────────────────────
# Anthropic Claude: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
# Google Gemini (optional second provider): https://aistudio.google.com/apikey
# Route each task to a provider in Settings → API Management.
GEMINI_API_KEY=YOUR_KEY_HERE

# ── Lead source API keys (all optional) ─────────────────────────────────────
# Google Places — real local businesses (Local module). https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=
# Apollo.io — company + decision-maker contacts (note: People Search needs a PAID plan).
APOLLO_API_KEY=
# Crunchbase — company / funding data.
CRUNCHBASE_API_KEY=
# BuiltWith — tech-stack detection.
BUILTWITH_API_KEY=
# Generic job-board source.
JOBS_API_KEY=
# Generic marketplace source.
MARKETPLACE_API_KEY=
# (RemoteOK + OpenStreetMap + AI Research need no key.)

# ── Auth (optional) ─────────────────────────────────────────────────────────
# Login is configured in-app (Settings → Security); a random session secret is
# generated and stored on first setup. Set AUTH_SECRET only to pin a fixed key
# (e.g. across multiple instances). Never commit a real value.
# AUTH_SECRET=

# ── Misc (optional) ─────────────────────────────────────────────────────────
# Override the SQLite file location (defaults to ./data/outreach.db).
# OUTREACH_DB_PATH=/absolute/path/to/outreach.db
# Force simulated mode regardless of keys (handy for demos).
# MOCK_MODE=true
# White-label app name (defaults to "OutreachPilot").
# NEXT_PUBLIC_APP_NAME=OutreachPilot
