# Copy this file to .env.local and fill in your key.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Optional: override the SQLite file location (defaults to ./data/outreach.db)
# OUTREACH_DB_PATH=/absolute/path/to/outreach.db

# Optional white-label branding (shown in the header / exports).
# Defaults to "OutreachPilot" if unset.
# NEXT_PUBLIC_APP_NAME=OutreachPilot
